{
  "name": "@markdownkit/markdownkit",
  "version": "2.1.1",
  "description": "Opinionated markdown formatter and linter for MD, MDX, MDC, and MDD files using Remark/Unified ecosystem",
  "keywords": [
    "formatter",
    "gfm",
    "linter",
    "markdown",
    "markdown-components",
    "markdown-linter",
    "markdownkit",
    "mdc",
    "mdd",
    "mdx",
    "nuxt-content",
    "opinionated",
    "remark",
    "unified"
  ],
  "homepage": "https://github.com/markdown-kit/markdownkit#readme",
  "bugs": {
    "url": "https://github.com/markdown-kit/markdownkit/issues"
  },
  "license": "MIT",
  "author": "Dominikos Pritis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markdown-kit/markdownkit.git"
  },
  "bin": {
    "markdownkit": "./cli.js",
    "markdownkit-setup": "./setup.js",
    "mdkit": "./cli.js"
  },
  "files": [
    ".remarkrc.js",
    ".remarkignore",
    ".oxlint-mdxrc.json",
    "setup.js",
    "cli.js",
    "text-processor.js",
    "README.md",
    "OXLINT_MDX_INTEGRATION.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./text-processor.js",
    "./text-processor": "./text-processor.js",
    "./setup": "./setup.js",
    "./cli": "./cli.js"
  },
  "scripts": {
    "lint:remark": "remark . --quiet --frail",
    "lint:oxlint-mdx": "oxlint-mdx \"**/*.{md,mdx,mdc,mdd}\"",
    "lint:oxlint-mdx:fix": "oxlint-mdx --fix \"**/*.{md,mdx,mdc,mdd}\"",
    "lint:all": "pnpm run lint:remark && pnpm run lint:oxlint-mdx",
    "format:remark": "remark . --output --quiet",
    "format:check-remark": "remark . --quiet",
    "check-links": "markdown-link-check **/*.{md,mdx,mdc,mdd}",
    "process": "pnpm run format:remark && pnpm run lint:all",
    "process:safe": "pnpm run format:check-remark && pnpm run lint:all",
    "nuclear": "node cli.js nuclear",
    "clean-cache": "rm -rf .remark-cache",
    "test": "pnpm run process:safe",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:ci": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "lint:fix-unsafe": "oxlint --import-plugin node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions --fix-dangerously .",
    "check:fix-suggestions": "oxlint --import-plugin node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions . && oxfmt --write .",
    "check": "pnpm run format:check && pnpm run lint:ci",
    "check:full": "pnpm run check && pnpm run test"
  },
  "dependencies": {
    "@adobe/remark-gridtables": "^3.0.18",
    "@code-dot-org/remark-plugins": "^2.0.1",
    "@markdownkit/oxlint-mdx": "^2.1.1",
    "@markdownkit/remark-mdd": "^2.1.0",
    "@theguild/remark-mermaid": "^0.3.0",
    "fumadocs-docgen": "^3.0.8",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "rehype-remark": "^10.0.1",
    "remark": "latest",
    "remark-directive": "^4.0.0",
    "remark-docx": "^0.3.26",
    "remark-emoji": "^5.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-linkify": "^1.1.0",
    "remark-lint": "^10.0.1",
    "remark-lint-alphabetize-lists": "^3.0.0",
    "remark-lint-definition-case": "^4.0.1",
    "remark-lint-emphasis-marker": "^4.0.1",
    "remark-lint-final-newline": "^3.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "remark-lint-hard-break-spaces": "^4.1.1",
    "remark-lint-heading-capitalization": "^1.3.0",
    "remark-lint-heading-increment": "^4.0.1",
    "remark-lint-heading-style": "^4.0.1",
    "remark-lint-link-title-style": "^4.0.1",
    "remark-lint-list-item-bullet-indent": "^5.0.1",
    "remark-lint-list-item-indent": "^4.0.1",
    "remark-lint-list-item-style": "^3.0.1",
    "remark-lint-match-punctuation": "^0.2.1",
    "remark-lint-maximum-line-length": "^4.1.1",
    "remark-lint-mdash-style": "^1.1.1",
    "remark-lint-mdx-jsx-attribute-sort": "^1.0.1",
    "remark-lint-mdx-jsx-no-void-children": "^1.0.1",
    "remark-lint-mdx-jsx-quote-style": "^1.0.1",
    "remark-lint-mdx-jsx-self-close": "^1.0.1",
    "remark-lint-no-dead-urls": "^2.0.1",
    "remark-lint-no-duplicate-headings": "^4.0.1",
    "remark-lint-no-duplicate-headings-in-section": "^4.0.1",
    "remark-lint-no-emphasis-as-heading": "^4.0.1",
    "remark-lint-no-empty-sections": "^4.0.0",
    "remark-lint-no-heading-indent": "^5.0.1",
    "remark-lint-no-heading-punctuation": "^4.0.1",
    "remark-lint-no-trailing-spaces": "^4.0.3",
    "remark-lint-ordered-list-marker-style": "^4.0.1",
    "remark-lint-ordered-list-marker-value": "^4.0.1",
    "remark-lint-strong-marker": "^4.0.1",
    "remark-lint-table-cell-padding": "^5.1.1",
    "remark-lint-table-pipe-alignment": "^4.1.1",
    "remark-lint-table-pipes": "^5.0.1",
    "remark-lint-unordered-list-marker-style": "^4.0.1",
    "remark-mdc": "^3.10.0",
    "remark-mdx": "^3.1.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-markdown-style-guide": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-preset-remcohaszing": "^3.1.1",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "remark-toc": "^9.0.0",
    "remark-typography": "^0.7.3",
    "remark-validate-links": "^13.1.0",
    "retext": "^9.0.0",
    "retext-english": "^5.0.0",
    "retext-sentence-spacing": "^6.0.0",
    "retext-smartypants": "^6.2.0",
    "retext-stringify": "^4.0.0",
    "to-vfile": "^8.0.0",
    "unified-lint-rule": "^3.0.1",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "vfile-reporter": "^8.1.1"
  },
  "devDependencies": {
    "markdown-link-check": "^3.14.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "remark-cli": "^12.0.1"
  },
  "engines": {
    "node": ">=22.x"
  }
}
